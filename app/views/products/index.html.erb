<div class="mx-auto max-w-6xl px-6 py-10">
  <div class="mb-8 flex items-center justify-between">
    <h1 class="text-2xl font-bold text-slate-900">商品一覧</h1>
    <div class="flex items-center gap-3">
      <button type="button" commandfor="new-product-dialog" command="show-modal" class="inline-flex items-center rounded-md bg-sky-700 px-4 py-2 text-sm font-semibold text-white hover:bg-sky-800 focus:outline-none focus:ring-2 focus:ring-sky-300">
        商品を追加する
      </button>
      <%= link_to "別ページで登録", new_product_path, class: "text-sm font-medium text-sky-700 hover:text-sky-900" %>
    </div>
  </div>

  <dialog id="new-product-dialog" aria-labelledby="new-product-dialog-title" aria-describedby="new-product-dialog-description" closedby="any" class="pointer-events-none invisible m-auto w-[calc(100vw-2rem)] max-w-2xl rounded-xl border border-slate-200 bg-white p-0 text-slate-900 shadow-2xl backdrop:bg-slate-900/40 backdrop:backdrop-blur-[1px] open:pointer-events-auto open:visible" <%= "open" if @open_new_product_dialog %>>
    <div class="relative">
      <div class="flex items-start justify-between border-b border-slate-200 px-6 py-4">
        <div class="space-y-1">
          <h2 id="new-product-dialog-title" class="text-xl font-bold text-slate-900">商品を追加</h2>
          <p id="new-product-dialog-description" class="text-sm text-slate-600">商品情報を入力して保存します。</p>
        </div>
        <button type="button" commandfor="new-product-dialog" command="close" aria-label="ダイアログを閉じる" class="rounded-md p-2 text-slate-500 hover:bg-slate-100 hover:text-slate-800 focus:outline-none focus:ring-2 focus:ring-slate-300">
          <span aria-hidden="true" class="text-lg leading-none">×</span>
        </button>
      </div>

      <div class="p-6">
        <%= render "form_errors", product: @new_product %>

        <%= form_with model: @new_product, url: products_path, class: "space-y-6" do |f| %>
          <%= hidden_field_tag :form_source, "index_dialog" %>
          <%= render "form_fields", f: f %>

          <div class="flex items-center justify-end gap-3 border-t border-slate-200 pt-4">
            <button type="submit" formmethod="dialog" formnovalidate class="inline-flex items-center rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-slate-300">
              キャンセル
            </button>
            <%= f.submit "保存する", class: "inline-flex items-center rounded-md bg-sky-700 px-4 py-2 text-sm font-semibold text-white hover:bg-sky-800 focus:outline-none focus:ring-2 focus:ring-sky-300" %>
          </div>
        <% end %>
      </div>
    </div>
  </dialog>

  <% if @products.empty? %>
    <div class="rounded-lg border border-dashed border-slate-300 bg-slate-50 p-6 text-center text-sm text-slate-600">
      商品がまだ登録されていません。
    </div>
  <% else %>
    <div class="overflow-x-auto rounded-xl border border-slate-200 bg-white shadow-sm">
      <table class="min-w-full divide-y divide-slate-200 text-left text-sm">
        <thead class="bg-slate-50 text-slate-700">
          <tr>
            <th class="px-4 py-3 font-semibold">ID</th>
            <th class="px-4 py-3 font-semibold">商品名</th>
            <th class="px-4 py-3 font-semibold">種類</th>
            <th class="px-4 py-3 font-semibold">入荷日</th>
            <th class="px-4 py-3 font-semibold">備考</th>
            <th class="px-4 py-3 font-semibold">作成日時</th>
            <th class="px-4 py-3 font-semibold">更新日時</th>
            <th class="px-4 py-3 font-semibold">操作</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 text-slate-800">
          <% @products.each do |product| %>
            <tr>
              <td class="px-4 py-3"><%= product.id %></td>
              <td class="px-4 py-3"><%= product.name %></td>
              <td class="px-4 py-3"><%= product.kind_label %></td>
              <td class="px-4 py-3"><%= product.arrival_date %></td>
              <td class="px-4 py-3"><%= product.note %></td>
              <td class="px-4 py-3"><%= product.created_at.in_time_zone("Tokyo").strftime("%Y-%m-%d %H:%M:%S %z") %></td>
              <td class="px-4 py-3"><%= product.updated_at.in_time_zone("Tokyo").strftime("%Y-%m-%d %H:%M:%S %z") %></td>
              <td class="px-4 py-3">
                <%= button_to "編集する", edit_product_path(product), method: :get, class: "inline-flex items-center rounded-md border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-slate-300" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <dialog id="edit-product-dialog" aria-labelledby="edit-product-dialog-title" aria-describedby="edit-product-dialog-description" closedby="none" class="fixed inset-0 z-50 pointer-events-none invisible m-0 h-screen w-screen max-w-none border-0 bg-transparent p-0 text-slate-900 open:pointer-events-auto open:visible" <%= "open" if @open_edit_dialog %>>
    <div class="relative flex h-full items-center justify-center p-4">
      <%= link_to products_path, aria: { label: "背景をクリックして一覧へ戻る" }, class: "absolute inset-0 z-0 block bg-slate-900/40 backdrop-blur-[1px]" do %>
        <span class="sr-only">背景をクリックして一覧へ戻る</span>
      <% end %>

      <div class="relative z-10 w-full max-w-2xl rounded-xl border border-slate-200 bg-white p-0 shadow-2xl">
        <div class="flex items-start justify-between border-b border-slate-200 px-6 py-4">
          <div class="space-y-1">
            <h2 id="edit-product-dialog-title" class="text-xl font-bold text-slate-900">商品を編集</h2>
            <p id="edit-product-dialog-description" class="text-sm text-slate-600">商品情報を更新して保存します。</p>
          </div>
          <%= link_to products_path, aria: { label: "一覧へ戻る" }, class: "rounded-md p-2 text-slate-500 hover:bg-slate-100 hover:text-slate-800 focus:outline-none focus:ring-2 focus:ring-slate-300" do %>
            <span aria-hidden="true" class="text-lg leading-none">×</span>
          <% end %>
        </div>

        <div class="p-6">
          <% if @edit_product %>
            <%= render "form_errors", product: @edit_product %>

            <%= form_with model: @edit_product, url: product_path(@edit_product), method: :patch, class: "space-y-6" do |f| %>
              <%= hidden_field_tag :form_source, "edit_dialog" %>
              <%= render "form_fields", f: f %>

              <div class="flex items-center justify-end gap-3 border-t border-slate-200 pt-4">
                <%= link_to "キャンセル", products_path, class: "inline-flex items-center rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-slate-300" %>
                <%= f.submit "保存する", class: "inline-flex items-center rounded-md bg-sky-700 px-4 py-2 text-sm font-semibold text-white hover:bg-sky-800 focus:outline-none focus:ring-2 focus:ring-sky-300" %>
              </div>
            <% end %>
          <% else %>
            <p class="text-sm text-slate-600">編集対象の商品が見つかりません。</p>
          <% end %>
        </div>
      </div>
    </div>
  </dialog>
</div>
