<div class="mx-auto max-w-3xl px-6 py-10">
  <div class="mb-8 flex items-center justify-between">
    <h1 class="text-2xl font-bold text-slate-900">商品登録</h1>
    <%= link_to "一覧へ戻る", products_path, class: "text-sm font-medium text-sky-700 hover:text-sky-900" %>
  </div>

  <% if @product.errors.any? %>
    <div class="mb-6 rounded-lg border border-red-200 bg-red-50 p-4">
      <p class="mb-2 text-sm font-semibold text-red-800">入力内容を確認してください</p>
      <ul class="list-inside list-disc text-sm text-red-700">
        <% @product.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: @product, url: products_path, class: "space-y-6 rounded-xl border border-slate-200 bg-white p-6 shadow-sm" do |f| %>
    <div class="space-y-2">
      <%= f.label :name, "商品名", class: "block text-sm font-semibold text-slate-800" %>
      <%= f.text_field :name, required: true, class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-900 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-200" %>
    </div>

    <div class="space-y-3">
      <p class="text-sm font-semibold text-slate-800">種類</p>
      <% kind_labels = { "food" => "食品", "miscellaneous" => "雑貨", "book" => "書籍" } %>
      <div class="space-y-2">
        <% Product.kinds.keys.each do |kind| %>
          <label class="flex cursor-pointer items-center gap-2 rounded-md border border-slate-200 px-3 py-2 hover:bg-slate-50">
            <%= f.radio_button :kind, kind, required: true, class: "h-4 w-4 border-slate-300 text-sky-600 focus:ring-sky-500" %>
            <span class="text-sm text-slate-800"><%= kind_labels.fetch(kind) %></span>
          </label>
        <% end %>
      </div>
    </div>

    <div class="space-y-2">
      <%= f.label :arrival_date, "入荷日", class: "block text-sm font-semibold text-slate-800" %>
      <%= f.date_field :arrival_date, required: true, class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-900 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-200" %>
    </div>

    <div class="space-y-2">
      <%= f.label :note, "備考", class: "block text-sm font-semibold text-slate-800" %>
      <%= f.text_area :note, rows: 4, class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-900 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-200" %>
    </div>

    <%= f.submit "保存する", class: "inline-flex items-center rounded-md bg-sky-700 px-4 py-2 text-sm font-semibold text-white hover:bg-sky-800 focus:outline-none focus:ring-2 focus:ring-sky-300" %>
  <% end %>
</div>
